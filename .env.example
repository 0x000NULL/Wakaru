# Database
# Generate a random password with: openssl rand -base64 32
DATABASE_URL="postgresql://wakaru_dev:<GENERATE_RANDOM_PASSWORD>@localhost:5432/wakaru_dev?schema=public"

# JWT Authentication
JWT_SECRET="dev-jwt-secret-change-in-production-minimum-32-chars"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-minimum-32-chars"

# DigitalOcean Spaces (Optional - for media hosting)
# If you're hosting videos/subtitles on DigitalOcean Spaces, configure these:
# DO_SPACES_ENDPOINT="https://sfo3.digitaloceanspaces.com"
# DO_SPACES_BUCKET="wakaru-media"

# FFmpeg (Optional - for audio extraction)
# Path to ffmpeg executable. Defaults to 'ffmpeg' (assumes it's in PATH)
# FFMPEG_PATH="ffmpeg"
